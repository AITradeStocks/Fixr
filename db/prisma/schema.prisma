generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Customer users ───────────────────────────────────────────────────────────
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  phone        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  jobs         Job[]
}

// ─── Contractor ───────────────────────────────────────────────────────────────
model Contractor {
  id                 String   @id @default(uuid())
  name               String
  telephone          String
  email              String   @unique
  passwordHash       String
  trade              String
  businessType       String
  zipCodes           String[]
  status             String
  rating             Float?
  insuranceUploaded  Boolean  @default(false)
  isLicensed         Boolean  @default(false)
  isVerified         Boolean  @default(false)
  // Extended profile fields
  headline           String?
  location           String?
  website            String?
  owner              String?
  abn                String?
  licenses           String[]
  postcode           String?
  about              String?
  logo_url           String?
  address            String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  jobs               Job[]
}

// ─── Job ─────────────────────────────────────────────────────────────────────
model Job {
  id                   String      @id @default(uuid())
  description          String
  location             String
  address              String?
  postcode             String?
  urgency              String
  category             String
  problemType          String
  severity             String
  estimatedTimeMinutes Int
  partsRequired        Boolean
  quotedPrice          Float
  quotedPriceMin       Float
  quotedPriceMax       Float
  confidence           String
  status               String
  // Customer link
  userId               String?
  user                 User?       @relation(fields: [userId], references: [id])
  // Contractor link
  contractorId         String?
  contractor           Contractor? @relation(fields: [contractorId], references: [id])
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  reviews              Review[]
}

// ─── Pricing events ───────────────────────────────────────────────────────────
model PricingEvent {
  id               String   @id @default(uuid())
  jobId            String?
  userId           String?
  inputDescription String
  location         String
  urgency          String
  predictedPrice   Float
  predictedMin     Float
  predictedMax     Float
  confidence       String
  modelVersion     String
  featuresJson     Json
  createdAt        DateTime @default(now())
}

// ─── Review ───────────────────────────────────────────────────────────────────
model Review {
  id        String   @id @default(uuid())
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id])
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
}

// ─── Contractor CRM leads ─────────────────────────────────────────────────────
model ContractorLead {
  id          String   @id @default(uuid())
  name        String
  phone       String
  tradeType   String
  suburbOrZip String
  source      String
  status      String
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Admin audit log ──────────────────────────────────────────────────────────
model AdminAction {
  id             String   @id @default(uuid())
  adminUserId    String?
  jobId          String
  actionType     String
  previousStatus String?
  newStatus      String?
  note           String?
  createdAt      DateTime @default(now())
}

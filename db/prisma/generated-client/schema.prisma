generator client {
  provider = "prisma-client-js"
  output   = "./generated-client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String
  name          String
  firstName     String   @default("")
  middleName    String?
  lastName      String   @default("")
  phone         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  jobs          Job[]
  reviews       Review[]
  cookieConsent Json?
}

model Contractor {
  id                String            @id @default(uuid())
  name              String
  firstName         String            @default("")
  middleName        String?
  lastName          String            @default("")
  passwordHash      String
  trade             String
  businessType      String
  zipCodes          String[]
  status            String
  rating            Float?
  insuranceUploaded Boolean           @default(false)
  isLicensed        Boolean           @default(false)
  isVerified        Boolean           @default(false)
  headline          String?
  location          String?
  website           String?
  owner             String?
  abn               String?
  licenses          String[]
  postcode          String?
  about             String?
  logo_url          String?
  address           String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  isContactVerified Boolean           @default(false)
  suburb            String?
  reviewCount       Int               @default(0)
  hiredCount        Int               @default(0)
  recommendations   Int               @default(0)
  profileUrl        String?
  emails            ContractorEmail[]
  phones            ContractorPhone[]
  jobs              Job[]
  reviews           Review[]
  cookieConsent     Json?
}

model ContractorEmail {
  id           String     @id @default(uuid())
  email        String     @unique
  type         String     @default("Personal")
  isVerified   Boolean    @default(false)
  contractorId String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  contractor   Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)
}

model ContractorPhone {
  id           String     @id @default(uuid())
  number       String
  type         String     @default("Personal")
  isVerified   Boolean    @default(false)
  contractorId String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  contractor   Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)
}

model Job {
  id                   String      @id @default(uuid())
  description          String
  location             String
  urgency              String
  category             String
  problemType          String
  severity             String
  estimatedTimeMinutes Int
  partsRequired        Boolean
  quotedPrice          Float
  quotedPriceMin       Float
  quotedPriceMax       Float
  confidence           String
  status               String
  userId               String?
  contractorId         String?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  address              String?
  postcode             String?
  customerLocation     Json?       @map("customer_location")
  contractor           Contractor? @relation(fields: [contractorId], references: [id])
  user                 User?       @relation(fields: [userId], references: [id])
  serviceCharge        Float?
  parts                Part[]
  reviews              Review?
  paymentStatus        String      @default("unpaid") // unpaid, pending, paid
  stripeSessionId      String?
}

model Part {
  id        String   @id @default(uuid())
  name      String
  price     Float
  status    String   @default("PENDING") // PENDING, APPROVED, REJECTED
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LocationLog {
  id           String   @id @default(cuid())
  jobId        String   @map("job_id")
  contractorId String   @map("contractor_id")
  lat          Float
  lng          Float
  accuracy     Float?
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([jobId, createdAt])
  @@map("location_logs")
}

model PricingEvent {
  id               String   @id @default(uuid())
  jobId            String?
  userId           String?
  inputDescription String
  location         String
  urgency          String
  predictedPrice   Float
  predictedMin     Float
  predictedMax     Float
  confidence       String
  modelVersion     String
  featuresJson     Json
  createdAt        DateTime @default(now())
}

model Review {
  id           String     @id @default(uuid())
  jobId        String     @unique
  rating       Int
  comment      String?
  createdAt    DateTime   @default(now())
  contractorId String
  customerId   String
  updatedAt    DateTime   @updatedAt
  contractor   Contractor @relation(fields: [contractorId], references: [id])
  customer     User       @relation(fields: [customerId], references: [id])
  job          Job        @relation(fields: [jobId], references: [id])
}

model ContractorLead {
  id          String   @id @default(uuid())
  name        String
  phone       String
  tradeType   String
  suburbOrZip String
  source      String
  status      String
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AdminAction {
  id             String   @id @default(uuid())
  adminUserId    String?
  jobId          String
  actionType     String
  previousStatus String?
  newStatus      String?
  note           String?
  createdAt      DateTime @default(now())
}

// ─── Verification codes ───────────────────────────────────────────────────────
model VerificationCode {
  id        String   @id @default(uuid())
  target    String // email or phone
  code      String
  type      String // "email" or "phone"
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([target, code])
}
